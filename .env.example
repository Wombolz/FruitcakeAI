# FruitcakeAI v5 — Environment Variables
# The preferred first-run path is ./scripts/bootstrap.sh, which will create .env
# for you and choose RAM-aware local model defaults.
# Copy manually only if you want to override that behavior: cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=fruitcake
DATABASE_URL=postgresql+asyncpg://fruitcake:fruitcake@localhost:5432/fruitcake_v5
DATABASE_URL_SYNC=postgresql+psycopg2://fruitcake:fruitcake@localhost:5432/fruitcake_v5

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ── LLM Backend — choose your default backend, optionally configure multiple
# providers, and expose selectable models in the client via *_MODELS. ──────────

# Local: Ollama (default — free, private, runs on your machine)
# Bootstrap may rewrite these defaults on first run:
# - <64 GB RAM: all 14b
# - >=64 GB RAM: mixed 14b/32b
LLM_BACKEND=ollama
LLM_MODEL=ollama_chat/qwen2.5:32b
LOCAL_API_BASE=http://localhost:11434/v1
LOCAL_API_KEY=sk-local
LOCAL_MODEL=qwen2.5:32b

# Optional multi-provider model registry for chat/task pickers.
# These lists control what appears in the UI. They do not replace LLM_MODEL,
# TASK_SMALL_MODEL, or TASK_LARGE_MODEL.
#
# One key per provider is supported in v1.
# Leave provider keys and model lists blank if you do not want that provider enabled.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_MODELS=gpt-5,gpt-5-mini,gpt-4o
ANTHROPIC_MODELS=claude-sonnet-4-6
GEMINI_MODELS=gemini-2.5-pro
LOCAL_MODELS=ollama_chat/qwen2.5:14b,ollama_chat/qwen2.5:32b

# Task-stage model routing
# LLM_MODEL remains the general default. When routing is enabled, task planning
# and execution stages can override it with the models below.
TASK_MODEL_ROUTING_ENABLED=true
TASK_SMALL_MODEL=ollama_chat/qwen2.5:14b
TASK_LARGE_MODEL=ollama_chat/qwen2.5:32b
TASK_FORCE_LARGE_FOR_PLANNING=false
TASK_FORCE_LARGE_FOR_FINAL_SYNTHESIS=true
TASK_LARGE_RETRY_ENABLED=true
TASK_LARGE_RETRY_MAX_ATTEMPTS=1

# Example mixed local/cloud setup:
# LLM_BACKEND=openai
# LLM_MODEL=gpt-5
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_MODELS=gpt-5,gpt-5-mini,gpt-4o
# ANTHROPIC_MODELS=claude-sonnet-4-6
# GEMINI_MODELS=gemini-2.5-pro
# LOCAL_MODELS=ollama_chat/qwen2.5:14b,ollama_chat/qwen2.5:32b
# TASK_SMALL_MODEL=ollama_chat/qwen2.5:14b
# TASK_LARGE_MODEL=gpt-5

# Cloud: Anthropic
# LLM_BACKEND=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Cloud: OpenAI
# LLM_BACKEND=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# Local: llama.cpp / LM Studio (openai-compatible)
# LLM_BACKEND=openai_compat
# LLM_MODEL=qwen2.5-14b
# LOCAL_API_BASE=http://localhost:8080/v1
# LOCAL_API_KEY=sk-local

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
STORAGE_DIR=./storage
WORKSPACE_DIR=./workspace
# Comma-separated absolute roots allowed for /library/link-folder.
# Leave blank to disable linked-folder ingestion entirely.
# Examples:
# LINKED_SOURCE_ALLOWED_ROOTS=/Users/you/Documents/FruitcakeLibrary
# LINKED_SOURCE_ALLOWED_ROOTS=/Users/you/Documents/FruitcakeLibrary,/Users/you/Shared/FruitcakeImports
LINKED_SOURCE_ALLOWED_ROOTS=
TOKENIZERS_PARALLELISM=false

# Optional HTTPS helper settings for ./scripts/start_https.sh
# Use a local/Tailscale hostname for alpha testing. For public domains, also
# edit Caddyfile and remove 'tls internal' so Caddy can obtain a real cert.
# FRUITCAKE_SITE_ADDRESS=fruitcake.localhost
# FRUITCAKE_UPSTREAM=127.0.0.1:30417

# ── APNs Push (Phase 4 Sprint 4.3) ────────────────────────────────────────────
# Leave blank to disable push delivery — tasks still run, results are not pushed.
# Obtain the .p8 key + Key ID + Team ID from developer.apple.com → Certificates.
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_AUTH_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8
# APNS_BUNDLE_ID=none.FruitcakeAi
# APNS_ENVIRONMENT=sandbox
